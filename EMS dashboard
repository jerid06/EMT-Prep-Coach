<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#090c11;--bg2:#0d1018;--surf:#111720;--surf2:#171e2b;
  --border:#1e2a3a;--border2:#263347;
  --red:#e63946;--red2:#ff4d5a;--amber:#f4a261;--green:#2dc653;--blue:#4fa3e0;
  --text:#b8cce0;--muted:#4d6070;--white:#eef3fa;
}
html{height:100%;}
body{background:var(--bg);color:var(--text);font-family:'Barlow',sans-serif;min-height:100vh;display:flex;overflow-x:hidden;}

/* scanlines */
body::before{content:’’;position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(255,255,255,.01) 2px,rgba(255,255,255,.01) 3px);pointer-events:none;z-index:999;}

/* ── SIDEBAR ── */
.sidebar{
width:220px;flex-shrink:0;
background:var(–bg2);
border-right:1px solid var(–border);
display:flex;flex-direction:column;
padding:24px 0;
position:fixed;top:0;left:0;bottom:0;
z-index:200;
}
.sidebar-logo{
display:flex;align-items:center;gap:10px;
padding:0 20px 28px;
text-decoration:none;
border-bottom:1px solid var(–border);
margin-bottom:20px;
}
.logo-icon{width:32px;height:32px;background:var(–red);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:16px;box-shadow:0 0 14px rgba(230,57,70,.4);}
.logo-text{font-family:‘Barlow Condensed’,sans-serif;font-weight:900;font-size:17px;letter-spacing:.07em;color:var(–white);}
.logo-text em{font-style:normal;color:var(–red);}

.nav-section{padding:0 12px;margin-bottom:6px;}
.nav-label{font-family:‘Barlow Condensed’,sans-serif;font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(–muted);padding:0 8px;margin-bottom:6px;}
.nav-item{
display:flex;align-items:center;gap:10px;
padding:9px 10px;border-radius:7px;
font-size:13px;font-weight:500;color:var(–muted);
cursor:pointer;transition:all .15s;text-decoration:none;
margin-bottom:2px;
}
.nav-item:hover{background:var(–surf);color:var(–text);}
.nav-item.active{background:rgba(230,57,70,.1);color:var(–white);border:1px solid rgba(230,57,70,.2);}
.nav-item.active .nav-icon-box{color:var(–red);}
.nav-icon-box{font-size:16px;width:20px;text-align:center;}

.sidebar-bottom{margin-top:auto;padding:16px 12px 0;border-top:1px solid var(–border);}
.user-card{
display:flex;align-items:center;gap:10px;
padding:10px;border-radius:8px;cursor:pointer;
transition:background .15s;
}
.user-card:hover{background:var(–surf);}
.user-avatar{
width:34px;height:34px;border-radius:50%;
background:linear-gradient(135deg,var(–red),#7b2d8b);
display:flex;align-items:center;justify-content:center;
font-family:‘Barlow Condensed’,sans-serif;font-size:14px;font-weight:800;color:white;
flex-shrink:0;
}
.user-name{font-family:‘Barlow Condensed’,sans-serif;font-size:14px;font-weight:700;color:var(–white);line-height:1;}
.user-plan{font-size:11px;color:var(–muted);}
.user-chevron{margin-left:auto;color:var(–muted);font-size:12px;}

/* ── MAIN ── */
.main{margin-left:220px;flex:1;display:flex;flex-direction:column;min-height:100vh;}

/* TOP BAR */
.topbar{
height:62px;display:flex;align-items:center;
padding:0 32px;
background:rgba(9,12,17,.9);backdrop-filter:blur(16px);
border-bottom:1px solid var(–border);
position:sticky;top:0;z-index:50;
gap:16px;
}
.topbar-title{
font-family:‘Barlow Condensed’,sans-serif;
font-size:20px;font-weight:800;color:var(–white);letter-spacing:.02em;
}
.topbar-sub{font-size:13px;color:var(–muted);margin-left:4px;}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:12px;}
.access-pill{
display:flex;align-items:center;gap:6px;
background:rgba(45,198,83,.08);border:1px solid rgba(45,198,83,.2);
border-radius:100px;padding:5px 12px;
font-family:‘Barlow Condensed’,sans-serif;font-size:11px;font-weight:700;
letter-spacing:.08em;text-transform:uppercase;color:var(–green);
}
.access-dot{width:5px;height:5px;background:var(–green);border-radius:50%;animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:.2;}}
.notif-btn{
width:34px;height:34px;border-radius:8px;
background:var(–surf);border:1px solid var(–border);
display:flex;align-items:center;justify-content:center;
cursor:pointer;font-size:15px;transition:all .15s;
position:relative;
}
.notif-btn:hover{border-color:var(–border2);}
.notif-badge{
position:absolute;top:-3px;right:-3px;
width:14px;height:14px;background:var(–red);border-radius:50%;
font-size:8px;font-weight:800;color:white;
display:flex;align-items:center;justify-content:center;
border:2px solid var(–bg);
}

/* ── CONTENT ── */
.content{padding:32px;flex:1;}

/* GREETING */
.greeting{margin-bottom:32px;animation:up .5s ease both;}
.greeting-time{
font-family:‘Barlow Condensed’,sans-serif;
font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
color:var(–red);margin-bottom:8px;
display:flex;align-items:center;gap:8px;
}
.greeting-time::before{content:’’;display:block;width:16px;height:1px;background:var(–red);}
.greeting-h{font-family:‘Barlow Condensed’,sans-serif;font-size:32px;font-weight:900;color:var(–white);margin-bottom:6px;}
.greeting-p{font-size:13px;font-weight:300;color:var(–muted);}

/* STATS ROW */
.stats-row{
display:grid;grid-template-columns:repeat(4,1fr);
gap:14px;margin-bottom:28px;
animation:up .5s .06s ease both;
}
.stat-card{
background:var(–surf);border:1px solid var(–border);border-radius:12px;
padding:20px;position:relative;overflow:hidden;
transition:border-color .2s,transform .2s;
}
.stat-card:hover{border-color:var(–border2);transform:translateY(-2px);}
.stat-card::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:var(–accent,var(–border));}
.stat-label{font-family:‘Barlow Condensed’,sans-serif;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(–muted);margin-bottom:10px;}
.stat-val{font-family:‘Barlow Condensed’,sans-serif;font-size:36px;font-weight:900;color:var(–white);line-height:1;margin-bottom:6px;}
.stat-sub{font-size:11px;color:var(–muted);display:flex;align-items:center;gap:4px;}
.stat-up{color:var(–green);}
.stat-down{color:var(–red);}

/* MAIN GRID */
.main-grid{
display:grid;grid-template-columns:1fr 320px;
gap:20px;
animation:up .5s .12s ease both;
}

/* START SESSION CARD */
.session-card{
background:var(–surf);border:1px solid var(–border);border-radius:14px;
padding:28px;position:relative;overflow:hidden;
}
.session-card::before{
content:’’;position:absolute;top:-80px;right:-80px;
width:300px;height:300px;
background:radial-gradient(circle,rgba(230,57,70,.06) 0%,transparent 65%);
pointer-events:none;
}
.session-title{font-family:‘Barlow Condensed’,sans-serif;font-size:18px;font-weight:800;color:var(–white);margin-bottom:4px;}
.session-sub{font-size:13px;color:var(–muted);margin-bottom:24px;}

.mode-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:24px;}
.mode-tile{
background:var(–surf2);border:1px solid var(–border);border-radius:10px;
padding:16px;cursor:pointer;transition:all .15s;
position:relative;
}
.mode-tile:hover{border-color:var(–border2);background:#1e2638;}
.mode-tile.selected{border-color:var(–red);background:rgba(230,57,70,.07);}
.mode-tile-icon{font-size:22px;margin-bottom:10px;display:block;}
.mode-tile-name{font-family:‘Barlow Condensed’,sans-serif;font-size:15px;font-weight:800;color:var(–white);margin-bottom:3px;}
.mode-tile-desc{font-size:11px;color:var(–muted);line-height:1.4;}
.mode-check{
position:absolute;top:10px;right:10px;
width:16px;height:16px;border-radius:50%;
background:var(–red);border:1px solid var(–red);
display:none;align-items:center;justify-content:center;
font-size:8px;color:white;
}
.mode-tile.selected .mode-check{display:flex;}

.cat-filter{margin-bottom:20px;}
.cat-filter-label{font-family:‘Barlow Condensed’,sans-serif;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(–muted);margin-bottom:10px;}
.cat-chips{display:flex;flex-wrap:wrap;gap:6px;}
.cat-chip{
display:flex;align-items:center;gap:5px;
background:var(–surf2);border:1px solid var(–border);border-radius:100px;
padding:5px 12px;font-size:12px;font-weight:500;color:var(–muted);
cursor:pointer;transition:all .15s;
}
.cat-chip:hover{border-color:var(–border2);color:var(–text);}
.cat-chip.active{border-color:var(–red);background:rgba(230,57,70,.08);color:var(–white);}
.cat-chip-dot{width:6px;height:6px;border-radius:50%;background:var(–cc,var(–muted));}

.start-row{display:flex;align-items:center;gap:12px;}
.start-btn{
flex:1;padding:14px;
background:var(–red);color:white;border:none;border-radius:8px;
font-family:‘Barlow Condensed’,sans-serif;font-size:16px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;
cursor:pointer;transition:all .15s;box-shadow:0 4px 20px rgba(230,57,70,.3);
}
.start-btn:hover{background:var(–red2);transform:translateY(-1px);box-shadow:0 8px 28px rgba(230,57,70,.4);}
.q-count-sel{font-size:13px;color:var(–muted);}
.q-count-sel select{
background:var(–surf2);border:1px solid var(–border);border-radius:6px;
color:var(–text);font-size:13px;padding:8px 10px;outline:none;
font-family:‘Barlow’,sans-serif;cursor:pointer;
}

/* RIGHT COLUMN */
.right-col{display:flex;flex-direction:column;gap:16px;}

/* ACCESS CARD */
.access-card{
background:linear-gradient(135deg,rgba(230,57,70,.1) 0%,var(–surf) 60%);
border:1px solid rgba(230,57,70,.3);border-radius:12px;padding:22px;
}
.access-card-title{font-family:‘Barlow Condensed’,sans-serif;font-size:14px;font-weight:800;color:var(–white);margin-bottom:4px;}
.access-card-sub{font-size:12px;color:var(–muted);margin-bottom:16px;}
.access-bar-bg{height:6px;background:var(–border);border-radius:3px;overflow:hidden;margin-bottom:8px;}
.access-bar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(–red),var(–amber));transition:width .6s ease;}
.access-days-row{display:flex;justify-content:space-between;font-size:11px;color:var(–muted);}
.access-days-row span:first-child{color:var(–amber);font-weight:600;}

/* STREAK CARD */
.streak-card{background:var(–surf);border:1px solid var(–border);border-radius:12px;padding:22px;}
.streak-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.streak-title{font-family:‘Barlow Condensed’,sans-serif;font-size:14px;font-weight:800;color:var(–white);}
.streak-num{font-family:‘Barlow Condensed’,sans-serif;font-size:28px;font-weight:900;color:var(–amber);}
.week-dots{display:flex;gap:6px;}
.week-dot{
flex:1;height:32px;border-radius:5px;
display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;
}
.week-dot-day{font-size:9px;color:var(–muted);font-weight:600;letter-spacing:.06em;text-transform:uppercase;}
.week-dot-bar{width:100%;height:18px;border-radius:3px;background:var(–border);}
.week-dot.done .week-dot-bar{background:var(–green);}
.week-dot.today .week-dot-bar{background:var(–amber);box-shadow:0 0 8px rgba(244,162,97,.4);}

/* CATEGORY PERFORMANCE */
.perf-card{background:var(–surf);border:1px solid var(–border);border-radius:12px;padding:22px;}
.perf-title{font-family:‘Barlow Condensed’,sans-serif;font-size:14px;font-weight:800;color:var(–white);margin-bottom:16px;}
.perf-row{display:flex;align-items:center;gap:10px;margin-bottom:11px;}
.perf-row:last-child{margin-bottom:0;}
.perf-emoji{font-size:14px;width:20px;text-align:center;}
.perf-name{font-size:12px;color:var(–text);min-width:90px;}
.perf-bar-bg{flex:1;height:5px;background:var(–border);border-radius:3px;overflow:hidden;}
.perf-bar-fill{height:100%;border-radius:3px;transition:width .8s ease;}
.perf-pct{font-family:‘Barlow Condensed’,sans-serif;font-size:12px;font-weight:700;min-width:32px;text-align:right;}

/* RECENT SESSIONS */
.recent-section{margin-top:20px;animation:up .5s .18s ease both;}
.recent-title{font-family:‘Barlow Condensed’,sans-serif;font-size:14px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(–muted);margin-bottom:14px;}
.sessions-list{display:flex;flex-direction:column;gap:8px;}
.session-row{
background:var(–surf);border:1px solid var(–border);border-radius:10px;
padding:14px 16px;display:flex;align-items:center;gap:14px;
transition:border-color .15s;cursor:pointer;
}
.session-row:hover{border-color:var(–border2);}
.session-row-icon{
width:36px;height:36px;border-radius:8px;
background:var(–surf2);border:1px solid var(–border);
display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;
}
.session-row-name{font-family:‘Barlow Condensed’,sans-serif;font-size:15px;font-weight:700;color:var(–white);}
.session-row-meta{font-size:11px;color:var(–muted);}
.session-row-score{
margin-left:auto;
font-family:‘Barlow Condensed’,sans-serif;font-size:20px;font-weight:900;
}
.score-good{color:var(–green);}
.score-mid{color:var(–amber);}
.score-low{color:var(–red);}
.session-row-date{font-size:11px;color:var(–muted);text-align:right;}

@keyframes up{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);}}

/* RESPONSIVE */
@media(max-width:1100px){
.main-grid{grid-template-columns:1fr;}
.right-col{display:grid;grid-template-columns:repeat(2,1fr);}
}
/* Hamburger button */
.hamburger{
display:none;
width:36px;height:36px;border-radius:8px;
background:var(–surf);border:1px solid var(–border);
align-items:center;justify-content:center;
cursor:pointer;flex-direction:column;gap:5px;
transition:border-color .15s;flex-shrink:0;
}
.hamburger:hover{border-color:var(–border2);}
.hamburger span{
display:block;width:16px;height:2px;
background:var(–text);border-radius:2px;
transition:all .25s ease;
}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0);}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

/* Sidebar overlay */
.sidebar-overlay{
position:fixed;inset:0;
background:rgba(0,0,0,.6);backdrop-filter:blur(4px);
z-index:199;opacity:0;pointer-events:none;
transition:opacity .3s;
}
.sidebar-overlay.visible{opacity:1;pointer-events:all;}

@media(max-width:768px){
.hamburger{display:flex;}
.sidebar{
transform:translateX(-100%);
transition:transform .3s cubic-bezier(.4,0,.2,1);
box-shadow:none;
}
.sidebar.open{
transform:translateX(0);
box-shadow:8px 0 32px rgba(0,0,0,.5);
}
/* overlay always in DOM, controlled by opacity/pointer-events */
.main{margin-left:0;}
.stats-row{grid-template-columns:repeat(2,1fr);}
.right-col{grid-template-columns:1fr;}
.content{padding:20px;}
}
</style>

