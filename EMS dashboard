<script>
// Run after DOM is ready
document.addEventListener('DOMContentLoaded', async function() {

  // Greeting by time of day
  const hour = new Date().getHours();
  const greet = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';
  const greetEl = document.getElementById('greeting-time');
  if (greetEl) greetEl.textContent = greet;

  // Load real user data from Supabase
  await loadUserData();

  // Close menu when a nav item is clicked on mobile
  document.querySelectorAll('.nav-item').forEach(item => {
    item.addEventListener('click', () => {
      if (window.innerWidth <= 768) closeMenu();
    });
  });

  // Close on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) closeMenu();
  });

});

async function loadUserData() {
  // Check session
  const { data: { session } } = await _supa.auth.getSession();
  if (!session) {
    window.location.href = 'ems-login.html';
    return;
  }
  const user = session.user;

  // Load profile
  const { data: profile } = await _supa.from('profiles').select('*').eq('id', user.id).single();
  if (profile) {
    const firstName = profile.first_name || user.email.split('@')[0];
    const greetH = document.querySelector('.greeting-h');
    if (greetH) greetH.textContent = 'Ready to study, ' + firstName + '?';
    const userName = document.querySelector('.user-name');
    if (userName) userName.textContent = firstName + ' ' + (profile.last_name || '');
    const userEmail = document.querySelector('.user-plan');
    if (userEmail) {
      // Load access
      const { data: access } = await _supa.from('access')
        .select('*').eq('user_id', user.id)
        .order('expires_at', { ascending: false }).limit(1).single();
      if (access) {
        const expires = new Date(access.expires_at);
        const now = new Date();
        const daysLeft = Math.max(0, Math.ceil((expires - now) / (1000 * 60 * 60 * 24)));
        const planNames = { monthly: 'Monthly', '90day': '90-Day', annual: 'Annual' };
        userEmail.textContent = (planNames[access.plan] || access.plan) + ' Access · ' + daysLeft + ' days left';
        // Update topbar pill
        const pill = document.querySelector('.access-pill');
        if (pill) pill.innerHTML = '<div class="access-dot"></div>' + planNames[access.plan] + ' · ' + daysLeft + ' days left';
        // Update access bar
        const planDays = { monthly: 30, '90day': 90, annual: 365 };
        const totalDays = planDays[access.plan] || 90;
        const usedDays = totalDays - daysLeft;
        const fillEl = document.querySelector('.access-bar-fill');
        if (fillEl) fillEl.style.width = Math.round((usedDays / totalDays) * 100) + '%';
        const daysRowSpan = document.querySelector('.access-days-row span:first-child');
        if (daysRowSpan) daysRowSpan.textContent = daysLeft + ' days left';
        // Check if expired
        if (daysLeft <= 0) {
          window.location.href = 'ems-checkout.html?expired=1';
          return;
        }
      } else {
        // No access record — send to checkout
        window.location.href = 'ems-checkout.html';
        return;
      }
    }
  }

  // Load session stats
  const { data: sessions } = await _supa.from('sessions')
    .select('*').eq('user_id', user.id).order('played_at', { ascending: false });

  if (sessions && sessions.length > 0) {
    // Total questions done
    const totalQ = sessions.reduce((s, r) => s + r.total, 0);
    const totalCorrect = sessions.reduce((s, r) => s + r.score, 0);
    const overallPct = totalQ > 0 ? Math.round((totalCorrect / totalQ) * 100) : 0;

    const qDoneEl = document.querySelector('.stat-card:nth-child(1) .stat-val');
    if (qDoneEl) qDoneEl.innerHTML = totalQ + '';
    const scorePctEl = document.querySelector('.stat-card:nth-child(2) .stat-val');
    if (scorePctEl) scorePctEl.innerHTML = overallPct + '<span style="font-size:20px;color:var(--muted)">%</span>';
    const sessionsEl = document.querySelector('.stat-card:nth-child(4) .stat-val');
    if (sessionsEl) sessionsEl.textContent = sessions.length;

    // Recent sessions list
    renderRecentSessions(sessions.slice(0, 4));
  }

  // Load cat stats
  const { data: catStats } = await _supa.from('cat_stats').select('*').eq('user_id', user.id);
  if (catStats && catStats.length > 0) {
    renderCatPerformance(catStats);
  }
}

function renderRecentSessions(sessions) {
  const list = document.querySelector('.sessions-list');
  if (!list) return;
  const modeIcons = { cat: '📚', mixed: '🎲', weak: '🔥', quick: '⚡' };
  const catEmojis = { airway: '💨', cardiac: '❤️', trauma: '🩹', medical: '💊', operations: '📻', pediatric: '🧒' };
  const modeNames = { cat: 'Category', mixed: 'Mixed Exam', weak: 'Weak Areas', quick: 'Quick 10' };
  list.innerHTML = sessions.map(s => {
    const pct = s.pct;
    const scoreClass = pct >= 75 ? 'score-good' : pct >= 50 ? 'score-mid' : 'score-low';
    const icon = s.category ? (catEmojis[s.category] || '📝') : (modeIcons[s.mode] || '📝');
    const name = s.mode === 'cat' && s.category
      ? s.category.charAt(0).toUpperCase() + s.category.slice(1) + ' — Category'
      : modeNames[s.mode] || s.mode;
    const date = new Date(s.played_at);
    const dateStr = date.toLocaleDateString('en-US', { weekday:'short', hour:'2-digit', minute:'2-digit' });
    return \`<div class="session-row">
      <div class="session-row-icon">\${icon}</div>
      <div>
        <div class="session-row-name">\${name}</div>
        <div class="session-row-meta">\${s.total} questions</div>
      </div>
      <div style="margin-left:auto;text-align:right">
        <div class="session-row-score \${scoreClass}">\${pct}%</div>
        <div class="session-row-date">\${dateStr}</div>
      </div>
    </div>\`;
  }).join('');
}

function renderCatPerformance(catStats) {
  const cats = ['airway','cardiac','trauma','medical','operations','pediatric'];
  const emojis = { airway:'💨', cardiac:'❤️', trauma:'🩹', medical:'💊', operations:'📻', pediatric:'🧒' };
  cats.forEach(cat => {
    const st = catStats.find(c => c.category === cat);
    if (!st || st.total === 0) return;
    const pct = Math.round((st.correct / st.total) * 100);
    const rows = document.querySelectorAll('.perf-row');
    rows.forEach(row => {
      const nameEl = row.querySelector('.perf-name');
      if (nameEl && nameEl.textContent.toLowerCase().includes(cat.slice(0,4))) {
        const bar = row.querySelector('.perf-bar-fill');
        const pctEl = row.querySelector('.perf-pct');
        const color = pct >= 75 ? 'var(--green)' : pct >= 50 ? 'var(--amber)' : 'var(--red)';
        if (bar) { bar.style.width = pct + '%'; bar.style.background = color; }
        if (pctEl) { pctEl.textContent = pct + '%'; pctEl.style.color = color; }
      }
    });
  });
}

// Mode selection
function selectMode(tile) {
  document.querySelectorAll('.mode-tile').forEach(t => t.classList.remove('selected'));
  tile.classList.add('selected');
  const name = tile.querySelector('.mode-tile-name');
  const isCat = name && name.textContent.trim() === 'Category';
  const catSection = document.getElementById('cat-filter-section');
  if (catSection) catSection.style.display = isCat ? 'block' : 'none';
}

// Category chips
function toggleChip(chip) {
  document.querySelectorAll('.cat-chip').forEach(c => c.classList.remove('active'));
  chip.classList.add('active');
}

// Launch session — passes mode + category to practice test
function launchSession() {
  const selected = document.querySelector('.mode-tile.selected');
  const modeName = selected ? selected.querySelector('.mode-tile-name').textContent.trim() : 'Category';
  const modeMap = {
    'Category': 'cat',
    'Mixed Exam': 'mixed',
    'Weak Areas': 'weak',
    'Quick 10': 'quick'
  };
  const mode = modeMap[modeName] || 'cat';
  const activeChip = document.querySelector('.cat-chip.active');
  const cat = activeChip ? activeChip.textContent.trim().toLowerCase() : 'airway';
  const catMap = {
    'airway': 'airway', 'cardiac': 'cardiac', 'trauma': 'trauma',
    'medical': 'medical', 'operations': 'operations', 'pediatric': 'pediatric'
  };
  const catId = catMap[cat] || 'airway';
  window.location.href = `ems-practice-test.html?mode=${mode}&cat=${catId}`;
}

// Hamburger menu
function toggleMenu() {
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  const hamburger = document.getElementById('hamburger');
  if (!sidebar) return;
  const isOpen = sidebar.classList.contains('open');
  if (isOpen) {
    closeMenu();
  } else {
    sidebar.classList.add('open');
    if (overlay) overlay.classList.add('visible');
    if (hamburger) hamburger.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
}

async function signOut() {
  await _supa.auth.signOut();
  window.location.href = 'ems-login.html';
}

function closeMenu() {
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  const hamburger = document.getElementById('hamburger');
  if (sidebar) sidebar.classList.remove('open');
  if (overlay) overlay.classList.remove('visible');
  if (hamburger) hamburger.classList.remove('open');
  document.body.style.overflow = '';
}
</script>

