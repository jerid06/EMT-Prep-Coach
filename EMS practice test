<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --bg:#090c11;--bg2:#0d1018;--surf:#111720;--surf2:#171e2b;
  --border:#1e2a3a;--border2:#263347;
  --red:#e63946;--red2:#ff4d5a;--amber:#f4a261;--green:#2dc653;--blue:#4fa3e0;
  --text:#b8cce0;--muted:#4d6070;--white:#eef3fa;
}
html,body{height:100%;}
body{background:var(--bg);color:var(--text);font-family:'Barlow',sans-serif;min-height:100vh;display:flex;flex-direction:column;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(255,255,255,.01) 2px,rgba(255,255,255,.01) 3px);pointer-events:none;z-index:999;}

/* ── NAV ── */
nav{height:58px;display:flex;align-items:center;padding:0 24px;background:rgba(9,12,17,.95);border-bottom:1px solid var(–border);position:sticky;top:0;z-index:100;backdrop-filter:blur(16px);gap:14px;flex-shrink:0;}
.nav-logo{display:flex;align-items:center;gap:9px;text-decoration:none;cursor:pointer;}
.nav-icon{width:30px;height:30px;background:var(–red);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;box-shadow:0 0 12px rgba(230,57,70,.4);transition:transform .15s;}
.nav-icon:hover{transform:scale(1.08);}
.nav-brand{font-family:‘Barlow Condensed’,sans-serif;font-weight:900;font-size:17px;letter-spacing:.07em;color:var(–white);}
.nav-brand em{font-style:normal;color:var(–red);}
.nav-sep{width:1px;height:20px;background:var(–border);}
.nav-cat-label{font-family:‘Barlow Condensed’,sans-serif;font-size:12px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(–red);background:rgba(230,57,70,.08);border:1px solid rgba(230,57,70,.25);border-radius:3px;padding:3px 10px;display:none;}
.nav-right{margin-left:auto;display:flex;align-items:center;gap:10px;}
.nav-diff-badge{font-family:‘Barlow Condensed’,sans-serif;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 9px;border-radius:3px;}
.diff-basic{background:rgba(45,198,83,.1);color:var(–green);border:1px solid rgba(45,198,83,.25);}
.diff-inter{background:rgba(244,162,97,.1);color:var(–amber);border:1px solid rgba(244,162,97,.25);}
.diff-adv{background:rgba(230,57,70,.1);color:var(–red);border:1px solid rgba(230,57,70,.25);}
.nav-progress{font-size:12px;color:var(–muted);font-family:‘Barlow Condensed’,sans-serif;font-weight:700;letter-spacing:.04em;}

/* ── MAIN LAYOUT ── */
.app{flex:1;display:flex;flex-direction:column;max-width:720px;width:100%;margin:0 auto;padding:0 16px;}

/* ── SCREEN: HOME ── */
#screen-home{padding:32px 0 60px;animation:up .45s ease both;}
.home-top{margin-bottom:32px;}
.home-kicker{font-family:‘Barlow Condensed’,sans-serif;font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(–red);display:flex;align-items:center;gap:8px;margin-bottom:10px;}
.home-kicker::before{content:’’;display:block;width:16px;height:1px;background:var(–red);}
.home-title{font-family:‘Barlow Condensed’,sans-serif;font-size:clamp(28px,6vw,44px);font-weight:900;color:var(–white);line-height:.95;margin-bottom:8px;}
.home-sub{font-size:13px;font-weight:300;color:var(–muted);line-height:1.6;}

/* MODE TILES */
.mode-row{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:24px;}
.mode-tile{background:var(–surf);border:1px solid var(–border);border-radius:12px;padding:20px 18px;cursor:pointer;transition:all .18s;position:relative;overflow:hidden;}
.mode-tile::after{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:var(–tc,var(–red));transform:scaleX(0);transform-origin:left;transition:transform .22s;}
.mode-tile:hover{border-color:var(–border2);transform:translateY(-2px);}
.mode-tile:hover::after{transform:scaleX(1);}
.mode-tile.active{border-color:var(–tc,var(–red));background:rgba(230,57,70,.06);}
.mode-tile.active::after{transform:scaleX(1);}
.mode-emoji{font-size:24px;margin-bottom:10px;display:block;}
.mode-name{font-family:‘Barlow Condensed’,sans-serif;font-size:16px;font-weight:800;color:var(–white);margin-bottom:3px;}
.mode-desc{font-size:11px;color:var(–muted);line-height:1.4;}
.mode-active-dot{position:absolute;top:10px;right:10px;width:8px;height:8px;border-radius:50%;background:var(–tc,var(–red));display:none;box-shadow:0 0 6px var(–tc,var(–red));}
.mode-tile.active .mode-active-dot{display:block;}

/* CAT GRID */
.cat-section-label{font-family:‘Barlow Condensed’,sans-serif;font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(–muted);margin-bottom:10px;}
.cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:24px;}
.cat-tile{background:var(–surf);border:1px solid var(–border);border-radius:10px;padding:14px 12px;cursor:pointer;transition:all .15s;position:relative;}
.cat-tile::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:var(–cc,var(–red));border-radius:2px 2px 0 0;transform:scaleX(0);transform-origin:left;transition:transform .2s;}
.cat-tile:hover{border-color:var(–border2);transform:translateY(-2px);}
.cat-tile:hover::before,.cat-tile.active::before{transform:scaleX(1);}
.cat-tile.active{border-color:var(–cc,var(–red));background:rgba(0,0,0,.2);}
.cat-tile-em{font-size:22px;margin-bottom:7px;display:block;}
.cat-tile-name{font-family:‘Barlow Condensed’,sans-serif;font-size:13px;font-weight:800;color:var(–white);margin-bottom:3px;line-height:1.1;}
.cat-tile-count{font-size:10px;color:var(–muted);}

/* Q COUNT ROW */
.q-row{display:flex;align-items:center;gap:10px;margin-bottom:28px;flex-wrap:wrap;}
.q-row-label{font-family:‘Barlow Condensed’,sans-serif;font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(–muted);}
.q-opts{display:flex;gap:6px;}
.q-opt{background:var(–surf);border:1px solid var(–border);border-radius:6px;padding:6px 14px;font-family:‘Barlow Condensed’,sans-serif;font-size:13px;font-weight:700;color:var(–muted);cursor:pointer;transition:all .15s;}
.q-opt:hover{border-color:var(–border2);color:var(–text);}
.q-opt.active{border-color:var(–red);background:rgba(230,57,70,.08);color:var(–white);}

.start-btn{width:100%;padding:16px;background:var(–red);color:white;border:none;border-radius:10px;font-family:‘Barlow Condensed’,sans-serif;font-size:17px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:all .15s;box-shadow:0 4px 24px rgba(230,57,70,.3);}
.start-btn:hover{background:var(–red2);transform:translateY(-2px);box-shadow:0 8px 32px rgba(230,57,70,.4);}

/* ── SCREEN: QUIZ ── */
#screen-quiz{padding:20px 0 60px;animation:up .3s ease both;display:none;}

/* Progress track */
.progress-track{margin-bottom:20px;}
.progress-nums{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.progress-label{font-family:‘Barlow Condensed’,sans-serif;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(–muted);}
.progress-pct{font-family:‘Barlow Condensed’,sans-serif;font-size:11px;font-weight:700;color:var(–muted);}
.progress-bar-bg{height:3px;background:var(–border);border-radius:2px;overflow:hidden;}
.progress-bar-fill{height:100%;background:linear-gradient(90deg,var(–red),var(–amber));border-radius:2px;transition:width .5s ease;}

/* Answer dots */
.dots-row{display:flex;gap:4px;margin-bottom:20px;flex-wrap:wrap;}
.ans-dot{width:10px;height:10px;border-radius:50%;background:var(–border);flex-shrink:0;transition:background .3s;}
.ans-dot.correct{background:var(–green);}
.ans-dot.wrong{background:var(–red);}
.ans-dot.current{background:var(–amber);box-shadow:0 0 6px var(–amber);}

/* Question card */
.q-card{background:var(–surf);border:1px solid var(–border);border-radius:14px;padding:24px;margin-bottom:14px;position:relative;overflow:hidden;}
.q-card::before{content:’’;position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(–red),transparent);}
.q-num{font-family:‘Barlow Condensed’,sans-serif;font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(–muted);margin-bottom:12px;}
.q-text{font-size:17px;font-weight:500;color:var(–white);line-height:1.55;}

/* Options */
.opts-list{display:flex;flex-direction:column;gap:9px;margin-bottom:16px;}
.opt-btn{background:var(–surf);border:1.5px solid var(–border);border-radius:9px;padding:14px 16px;text-align:left;cursor:pointer;color:var(–text);font-family:‘Barlow’,sans-serif;font-size:15px;transition:all .15s;display:flex;align-items:flex-start;gap:12px;line-height:1.45;}
.opt-btn:hover:not(:disabled){border-color:var(–amber);background:var(–surf2);transform:translateX(3px);}
.opt-btn:hover:not(:disabled) .opt-letter{color:var(–amber);}
.opt-letter{font-family:‘Barlow Condensed’,sans-serif;font-weight:800;font-size:13px;color:var(–muted);min-width:18px;flex-shrink:0;margin-top:1px;transition:color .15s;}
.opt-btn.correct{border-color:var(–green);background:rgba(45,198,83,.07);}
.opt-btn.correct .opt-letter{color:var(–green);}
.opt-btn.wrong{border-color:var(–red);background:rgba(230,57,70,.07);}
.opt-btn.wrong .opt-letter{color:var(–red);}
.opt-btn.reveal{border-color:rgba(45,198,83,.4);background:rgba(45,198,83,.04);}
.opt-btn:disabled{cursor:default;transform:none !important;}

/* Explanation */
.explanation{background:var(–surf2);border-left:3px solid var(–amber);border-radius:0 8px 8px 0;padding:13px 15px;font-size:13px;color:var(–text);line-height:1.65;margin-bottom:16px;display:none;animation:fadeIn .3s ease;}
.explanation strong{color:var(–amber);font-weight:600;}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}

/* Next btn */
.next-btn{width:100%;padding:14px;background:var(–red);color:white;border:none;border-radius:9px;font-family:‘Barlow Condensed’,sans-serif;font-size:16px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:all .15s;display:none;box-shadow:0 4px 20px rgba(230,57,70,.25);}
.next-btn:hover{background:var(–red2);transform:translateY(-1px);box-shadow:0 8px 28px rgba(230,57,70,.35);}

/* ── SCREEN: RESULTS ── */
#screen-results{padding:32px 0 60px;text-align:center;display:none;animation:up .4s ease both;}

.result-ring-wrap{margin-bottom:24px;}
.result-ring{width:130px;height:130px;border-radius:50%;margin:0 auto;display:flex;align-items:center;justify-content:center;position:relative;}
.result-ring::after{content:’’;position:absolute;inset:11px;background:var(–bg);border-radius:50%;}
.result-inner{position:relative;z-index:1;text-align:center;}
.result-pct{font-family:‘Barlow Condensed’,sans-serif;font-size:38px;font-weight:900;color:var(–white);line-height:1;}
.result-pct-label{font-size:10px;color:var(–muted);letter-spacing:.1em;text-transform:uppercase;}

.result-title{font-family:‘Barlow Condensed’,sans-serif;font-size:28px;font-weight:900;color:var(–white);margin-bottom:6px;}
.result-sub{font-size:13px;font-weight:300;color:var(–muted);margin-bottom:28px;}

.result-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:24px;}
.res-stat{background:var(–surf);border:1px solid var(–border);border-radius:10px;padding:14px 10px;}
.res-stat-val{font-family:‘Barlow Condensed’,sans-serif;font-size:28px;font-weight:900;display:block;margin-bottom:3px;}
.res-stat-label{font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:var(–muted);}

.cat-breakdown{background:var(–surf);border:1px solid var(–border);border-radius:12px;padding:18px;margin-bottom:24px;text-align:left;}
.cat-bd-title{font-family:‘Barlow Condensed’,sans-serif;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(–muted);margin-bottom:14px;}
.cat-bd-row{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
.cat-bd-row:last-child{margin-bottom:0;}
.cat-bd-em{font-size:13px;width:18px;text-align:center;}
.cat-bd-name{font-size:12px;color:var(–text);min-width:100px;}
.cat-bd-bar-bg{flex:1;height:5px;background:var(–border);border-radius:3px;overflow:hidden;}
.cat-bd-bar-fill{height:100%;border-radius:3px;transition:width .7s ease;}
.cat-bd-pct{font-family:‘Barlow Condensed’,sans-serif;font-size:12px;font-weight:700;min-width:34px;text-align:right;}

.result-btns{display:flex;gap:10px;flex-wrap:wrap;}
.res-btn-sec{flex:1;background:var(–surf);border:1.5px solid var(–border);color:var(–text);border-radius:9px;padding:13px;font-family:‘Barlow Condensed’,sans-serif;font-size:14px;font-weight:800;letter-spacing:.06em;text-transform:uppercase;cursor:pointer;transition:all .15s;min-width:110px;}
.res-btn-sec:hover{border-color:var(–muted);color:var(–white);background:var(–surf2);}

@keyframes up{from{opacity:0;transform:translateY(16px);}to{opacity:1;transform:translateY(0);}}

@media(max-width:480px){
.mode-row{grid-template-columns:1fr 1fr;}
.cat-grid{grid-template-columns:repeat(2,1fr);}
.result-stats{grid-template-columns:repeat(3,1fr);}
}
</style>

