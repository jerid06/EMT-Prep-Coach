// =====================================================
// CATEGORIES
// =====================================================
const CATEGORIES = [
  {id:'airway',    name:'Airway',      full:'Airway & Breathing',   emoji:'💨', color:'#4fa3e0', count:87},
  {id:'cardiac',   name:'Cardiac',     full:'Cardiac & Circulation',emoji:'❤️',  color:'#e63946', count:123},
  {id:'trauma',    name:'Trauma',      full:'Trauma',               emoji:'🩹', color:'#f4a261', count:93},
  {id:'medical',   name:'Medical',     full:'Medical Emergencies',  emoji:'💊', color:'#2dc653', count:116},
  {id:'operations',name:'Operations',  full:'EMS Operations',       emoji:'📻', color:'#a78bfa', count:93},
  {id:'pediatric', name:'Pediatric',   full:'Pediatric Care',       emoji:'🧒', color:'#f472b6', count:105},
];

// =====================================================
// STATE
// =====================================================
let mode = 'cat';
let selectedCat = 'airway';
let qCount = 20;
let currentQuestions = [];
let currentIndex = 0;
let score = 0;
let answered = false;
let sessionHistory = []; // {catId, correct}
let catStats = {};
CATEGORIES.forEach(c => catStats[c.id] = {correct:0, total:0});
let lastSession = null;

// =====================================================
// INIT
// =====================================================
function init() {
  buildCatGrid();
  document.getElementById('mode-cat').click();
}

function buildCatGrid() {
  const grid = document.getElementById('cat-grid');
  grid.innerHTML = '';
  CATEGORIES.forEach(cat => {
    const tile = document.createElement('div');
    tile.className = 'cat-tile' + (cat.id === selectedCat ? ' active' : '');
    tile.style.setProperty('--cc', cat.color);
    tile.innerHTML = `<span class="cat-tile-em">${cat.emoji}</span><div class="cat-tile-name">${cat.name}</div><div class="cat-tile-count">${cat.count} questions</div>`;
    tile.onclick = () => {
      document.querySelectorAll('.cat-tile').forEach(t => t.classList.remove('active'));
      tile.classList.add('active');
      selectedCat = cat.id;
    };
    grid.appendChild(tile);
  });
}

// =====================================================
// MODE / Q COUNT SELECTION
// =====================================================
function selectMode(el, m) {
  document.querySelectorAll('.mode-tile').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  mode = m;
  const catSection = document.getElementById('cat-select-section');
  catSection.style.display = (m === 'cat') ? 'block' : 'none';
}

function selectQCount(el, n) {
  document.querySelectorAll('.q-opt').forEach(o => o.classList.remove('active'));
  el.classList.add('active');
  qCount = n;
}

// =====================================================
// START SESSION
// =====================================================
function startSession() {
  let pool = [];
  if (mode === 'cat') {
    pool = [...QBANK[selectedCat]];
  } else if (mode === 'mixed') {
    CATEGORIES.forEach(c => pool.push(...QBANK[c.id].map(q => ({...q, _cat: c.id}))));
  } else if (mode === 'weak') {
    const weak = CATEGORIES.filter(c => {
      const st = catStats[c.id];
      return st.total === 0 || (st.correct / st.total) < 0.7;
    });
    const ids = weak.length > 0 ? weak.map(c => c.id) : CATEGORIES.map(c => c.id);
    ids.forEach(id => pool.push(...QBANK[id].map(q => ({...q, _cat: id}))));
  } else if (mode === 'quick') {
    CATEGORIES.forEach(c => pool.push(...QBANK[c.id].map(q => ({...q, _cat: c.id}))));
    qCount = 10;
  }

  // Shuffle
  for (let i = pool.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [pool[i], pool[j]] = [pool[j], pool[i]];
  }

  currentQuestions = pool.slice(0, qCount);
  currentIndex = 0;
  score = 0;
  answered = false;
  sessionHistory = [];

  // Update nav
  const catLabel = document.getElementById('nav-cat');
  const catObj = CATEGORIES.find(c => c.id === selectedCat);
  catLabel.textContent = mode === 'cat' ? catObj?.name : mode === 'mixed' ? 'Mixed' : mode === 'weak' ? 'Weak Areas' : 'Quick 10';
  catLabel.style.display = 'block';

  showScreen('quiz');
  buildDots();
  renderQuestion();
}

// =====================================================
// RENDER QUESTION
// =====================================================
function renderQuestion() {
  answered = false;
  const q = currentQuestions[currentIndex];
  const total = currentQuestions.length;

  // Progress
  const pct = Math.round((currentIndex / total) * 100);
  document.getElementById('progress-label').textContent = `Question ${currentIndex + 1} of ${total}`;
  document.getElementById('progress-pct').textContent = `${pct}%`;
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('nav-progress').textContent = `${currentIndex + 1}/${total}`;
  document.getElementById('nav-progress').style.display = 'block';

  // Difficulty badge
  const diff = document.getElementById('nav-diff');
  diff.style.display = 'block';
  diff.className = 'nav-diff-badge ' + (q.d === 1 ? 'diff-basic' : q.d === 2 ? 'diff-inter' : 'diff-adv');
  diff.textContent = q.d === 1 ? 'Basic' : q.d === 2 ? 'Intermediate' : 'Advanced';

  document.getElementById('q-num').textContent = `Question ${currentIndex + 1}`;
  document.getElementById('q-text').textContent = q.q;
  document.getElementById('explanation').style.display = 'none';
  document.getElementById('next-btn').style.display = 'none';

  const optsList = document.getElementById('opts-list');
  optsList.innerHTML = '';
  const letters = ['A','B','C','D'];
  q.opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'opt-btn';
    btn.innerHTML = `<span class="opt-letter">${letters[i]}</span><span>${opt}</span>`;
    btn.onclick = () => selectAnswer(i, btn);
    optsList.appendChild(btn);
  });

  updateDots();

  // Scroll top
  document.querySelector('.app').scrollTop = 0;
  window.scrollTo(0, 0);
}

function selectAnswer(idx, btn) {
  if (answered) return;
  answered = true;

  const q = currentQuestions[currentIndex];
  const allBtns = document.querySelectorAll('.opt-btn');
  allBtns.forEach(b => b.disabled = true);

  const correct = idx === q.ans;
  if (correct) {
    btn.classList.add('correct');
    score++;
  } else {
    btn.classList.add('wrong');
    allBtns[q.ans]?.classList.add('reveal');
  }

  // Track stats
  const catId = q._cat || selectedCat;
  catStats[catId].total++;
  if (correct) catStats[catId].correct++;
  sessionHistory.push({catId, correct});

  // Explanation
  const exp = document.getElementById('explanation');
  exp.innerHTML = `<strong>Explanation:</strong> ${q.exp}`;
  exp.style.display = 'block';

  // Next button
  const nextBtn = document.getElementById('next-btn');
  nextBtn.textContent = currentIndex < currentQuestions.length - 1 ? 'Next Question →' : 'See Results →';
  nextBtn.style.display = 'block';

  updateDots();
}

function nextQuestion() {
  currentIndex++;
  if (currentIndex >= currentQuestions.length) {
    showResults();
  } else {
    renderQuestion();
  }
}

// =====================================================
// DOTS
// =====================================================
function buildDots() {
  const row = document.getElementById('dots-row');
  row.innerHTML = '';
  currentQuestions.forEach((_, i) => {
    const dot = document.createElement('div');
    dot.className = 'ans-dot';
    row.appendChild(dot);
  });
}

function updateDots() {
  const dots = document.querySelectorAll('.ans-dot');
  dots.forEach((dot, i) => {
    dot.className = 'ans-dot';
    if (i < currentIndex) {
      dot.classList.add(sessionHistory[i]?.correct ? 'correct' : 'wrong');
    } else if (i === currentIndex) {
      dot.classList.add('current');
    }
  });
}

// =====================================================
// RESULTS
// =====================================================
function showResults() {
  const total = currentQuestions.length;
  const pct = Math.round((score / total) * 100);

  // Ring
  const color = pct >= 75 ? 'var(--green)' : pct >= 50 ? 'var(--amber)' : 'var(--red)';
  const ring = document.getElementById('result-ring');
  ring.style.background = `conic-gradient(${color} ${pct}%, var(--border) ${pct}%)`;

  document.getElementById('result-pct').textContent = pct + '%';
  document.getElementById('rs-correct').textContent = score;
  document.getElementById('rs-wrong').textContent = total - score;
  document.getElementById('rs-total').textContent = total;

  // Title
  let title, sub;
  if (pct >= 90) { title = 'Outstanding 🎖️'; sub = 'You are ready for the real thing.'; }
  else if (pct >= 75) { title = 'Great Work ✅'; sub = 'Solid understanding — review your misses.'; }
  else if (pct >= 50) { title = 'Keep Studying 📚'; sub = 'You are on your way — review the material.'; }
  else { title = 'More Practice Needed 💪'; sub = 'Do not give up — review and try again.'; }
  document.getElementById('result-title').textContent = title;
  document.getElementById('result-sub').textContent = sub;

  // Category breakdown (only show if mixed/weak/quick or multiple sessions)
  const breakdown = document.getElementById('cat-breakdown');
  const bdRows = document.getElementById('cat-bd-rows');
  const hasCatData = CATEGORIES.some(c => catStats[c.id].total > 0);
  if (hasCatData) {
    bdRows.innerHTML = '';
    CATEGORIES.forEach(cat => {
      const st = catStats[cat.id];
      if (st.total === 0) return;
      const p = Math.round((st.correct / st.total) * 100);
      const barColor = p >= 75 ? 'var(--green)' : p >= 50 ? 'var(--amber)' : 'var(--red)';
      bdRows.innerHTML += `
        <div class="cat-bd-row">
          <span class="cat-bd-em">${cat.emoji}</span>
          <span class="cat-bd-name">${cat.name}</span>
          <div class="cat-bd-bar-bg"><div class="cat-bd-bar-fill" style="width:${p}%;background:${barColor}"></div></div>
          <span class="cat-bd-pct" style="color:${barColor}">${p}%</span>
        </div>`;
    });
    breakdown.style.display = 'block';
  }

  lastSession = { mode, selectedCat, qCount };
  showScreen('results');
  saveSession(pct);
}

async function saveSession(pct) {
  const { data: { session } } = await _supa.auth.getSession();
  if (!session) return; // not logged in, skip saving

  const userId = session.user.id;
  const total = currentQuestions.length;

  // Save session record
  await _supa.from('sessions').insert({
    user_id: userId,
    mode: mode,
    category: mode === 'cat' ? selectedCat : null,
    score: score,
    total: total,
    pct: pct,
  });

  // Upsert cat_stats for each category answered
  const catTotals = {};
  sessionHistory.forEach(h => {
    if (!catTotals[h.catId]) catTotals[h.catId] = { correct: 0, total: 0 };
    catTotals[h.catId].total++;
    if (h.correct) catTotals[h.catId].correct++;
  });

  for (const [cat, stats] of Object.entries(catTotals)) {
    // Try to get existing record first
    const { data: existing } = await _supa.from('cat_stats')
      .select('*').eq('user_id', userId).eq('category', cat).single();
    if (existing) {
      await _supa.from('cat_stats').update({
        correct: existing.correct + stats.correct,
        total: existing.total + stats.total,
        updated_at: new Date().toISOString()
      }).eq('user_id', userId).eq('category', cat);
    } else {
      await _supa.from('cat_stats').insert({
        user_id: userId,
        category: cat,
        correct: stats.correct,
        total: stats.total
      });
    }
  }
}

// =====================================================
// SCREEN SWITCHING
// =====================================================
function showScreen(name) {
  ['home','quiz','results'].forEach(s => {
    document.getElementById('screen-' + s).style.display = 'none';
  });
  document.getElementById('screen-' + name).style.display = 'block';
  document.getElementById('screen-' + name).style.animation = 'none';
  document.getElementById('screen-' + name).offsetHeight;
  document.getElementById('screen-' + name).style.animation = '';

  // Nav state
  const catLabel = document.getElementById('nav-cat');
  const diff = document.getElementById('nav-diff');
  const prog = document.getElementById('nav-progress');
  if (name === 'home') {
    catLabel.style.display = 'none';
    diff.style.display = 'none';
    prog.style.display = 'none';
  }
}

function goHome() {
  showScreen('home');
}

function retrySession() {
  if (lastSession) {
    mode = lastSession.mode;
    selectedCat = lastSession.selectedCat;
    qCount = lastSession.qCount;
    sessionHistory = [];
    startSession();
  } else {
    goHome();
  }
}

init();

// Auto-start from URL params (e.g. from dashboard)
(function() {
  const params = new URLSearchParams(window.location.search);
  const modeParam = params.get('mode');
  const catParam = params.get('cat');
  if (!modeParam) return; // no params, show home screen normally

  // Set mode
  const modeEl = document.getElementById('mode-' + modeParam);
  if (modeEl) {
    selectMode(modeEl, modeParam);
    // Visually activate the tile
    document.querySelectorAll('.mode-tile').forEach(t => t.classList.remove('active'));
    modeEl.classList.add('active');
  }

  // Set category if provided
  if (catParam && modeParam === 'cat') {
    const catTiles = document.querySelectorAll('.cat-tile');
    catTiles.forEach(tile => {
      tile.classList.remove('active');
      if (tile.querySelector('.cat-tile-name') &&
          tile.querySelector('.cat-tile-name').textContent.trim().toLowerCase() === catParam) {
        tile.classList.add('active');
        selectedCat = catParam;
      }
    });
  }

  // Auto-start the session
  startSession();
})();
</script>

